{
  "name": "controller-lab",
  "version": "1.0.0",
  "description": "Modular controller lab for testing and calibrating PlayStation and Xbox controllers",
  "main": "js/main.js",
  "type": "module",
  "scripts": {
    "build": "gulp build",
    "build:prod": "gulp build --production",
    "clean": "gulp clean",
    "dev": "gulp dev",
    "watch": "gulp watch",
    "serve": "http-server dist -p 8080",
    "serve:https": "http-server dist -S -C cert.pem -K key.pem -p 8443",
    "start": "npm run build && npm run serve",
    "dev:serve": "npm run build && concurrently \"npm run dev\" \"npm run serve\"",
    "dev:full": "npm run build && concurrently --kill-others \"npm run watch\" \"npm run serve\"",
    "lint": "eslint js/**/*.js",
    "format": "prettier --write js/**/*.js",
    "test": "jest"
  },
  "devDependencies": {
    "@babel/core": "^7.24.7",
    "@babel/preset-env": "^7.24.7",
    "rollup": "^4.9.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "gulp": "^5.0.1",
    "gulp-cli": "^3.1.0",
    "gulp-terser": "^2.1.0",
    "gulp-clean-css": "^4.3.0",
    "gulp-htmlmin": "^5.0.1",
    "gulp-rev": "^11.0.0",
    "gulp-rev-replace": "^0.4.4",
    "gulp-concat": "^2.6.1",
    "gulp-sourcemaps": "^3.0.0",
    "gulp-if": "^3.0.0",
    "gulp-rename": "^2.1.0",
    "rollup-stream": "^1.24.1",
    "vinyl-source-stream": "^2.0.0",
    "vinyl-buffer": "^1.0.1",
    "del": "^8.0.0",
    "yargs": "^18.0.0",
    "gulp-svgmin": "^4.1.0",
    "gulp-replace": "^1.1.4",
    "gulp-json-minify": "^1.2.3",
    "glob": "^10.3.10",
    "html-minifier-terser": "^7.2.0",
    "concurrently": "^8.2.2",
    "http-server": "^14.1.1",
    "eslint": "^8.57.0",
    "prettier": "^3.3.2",
    "jest": "^29.7.0",
    "babel-jest": "^29.7.0"
  },
  "keywords": [
    "controller",
    "gamepad",
    "playstation",
    "xbox",
    "dualshock",
    "dualsense",
    "calibration",
    "webhid"
  ],
  "author": "",
  "license": "MIT"
}